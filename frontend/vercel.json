{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://practice-management-system-production.up.railway.app/api/$1"
    },
    {
      "src": "/((?!static/).*)",
      "dest": "/index.html"
    }
  ]
}